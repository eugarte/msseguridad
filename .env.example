# Environment Configuration
NODE_ENV=development

# Server
PORT=3000
HOST=0.0.0.0

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=msseg_user
DB_PASSWORD=msseg_pass_2024
DB_DATABASE=msseguridad
DB_SYNC=false
DB_LOGGING=true

# Cache - Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=msseguridad
JWT_AUDIENCE=msseguridad-api

# Security
BCRYPT_ROUNDS=12
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
MFA_ISSUER=msseguridad-app

# Session
SESSION_SECRET=change-this-in-production
SESSION_EXPIRATION=30d
MAX_SESSIONS_PER_USER=10

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@msseguridad.local

# OAuth2
OAUTH_CODE_EXPIRATION=10m
OAUTH_ACCESS_EXPIRATION=1h
OAUTH_REFRESH_EXPIRATION=30d
OAUTH_REQUIRE_PKCE=true

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
LOG_LEVEL=debug
LOG_FORMAT=json

# Audit
AUDIT_RETENTION_DAYS=365
AUDIT_BATCH_SIZE=1000

# Feature Flags
ENABLE_MFA=true
ENABLE_OAUTH=true
ENABLE_REGISTRATION=true
ENABLE_PASSWORD_RESET=true

# mssistemas Integration
MSSISTEMAS_URL=http://localhost:3001
MSSISTEMAS_API_KEY=your-api-key-here
SERVICE_NAME=msseguridad
SERVICE_VERSION=1.0.0
SERVICE_BASE_URL=http://localhost:3000
HEARTBEAT_INTERVAL_MS=30000
